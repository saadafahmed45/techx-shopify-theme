<div class="richtext_section">
    <div class="container">
        <div class="richtext_content text-{{ section.settings.text_align }}">
            <h2>{{ section.settings.heading }}</h2>
            <p>{{ section.settings.text }}</p>
            <div>
                <button class="btn btn-dark"> {{ section.settings.button_text }}</button>
            </div>
        </div>
    </div>
</div>

<style>
    .richtext_section {
        padding: 60px 20px;

        background: {
                {
                section.settings.bg_color
            }
        }

        ;
    }

    .richtext_content {
        max-width: 800px;
        margin: 0 auto;
        font-size: 18px;
        line-height: 1.6;

        color: {
                {
                section.settings.text_color
            }
        }

        ;
    }
</style>

{% schema %}
{
"name": "Rich-Text",
"settings": [
{
"type": "text",
"id": "heading",
"label": "Heading",
"default": "Rich Text Section"
},
{
"type": "richtext",
"id": "text",
"label": "Text",
"default": "<p>This is a rich text section. You can add any content here, including links, lists, and more.</p>"
},
{
"type": "text",
"id": "button_text",
"label": "Button Text",
"default": "Learn More"
},



{
"type": "select",
"id": "text_align",
"label": "Text Alignment",
"default": "center",
"options": [
{ "value": "left", "label": "Left" },
{ "value": "center", "label": "Center" },
{ "value": "right", "label": "Right" }
]
}
],
"presets": [
{
"name": "Rich-Text",
"category": "Custom Sections",
"settings": {
}
}
]
}
{% endschema %}