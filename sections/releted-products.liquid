<div class="releted_products">
    <div class="container">
        {% if product.collections.size > 0 %}
        {% assign collection = product.collections.first %}
        <h3>Related Products</h3>
        <div class="related-products">
            {% for related_product in collection.products %}
            {% if related_product.id != product.id %}
            <div class="related-product-item">
                <a href="{{ related_product.url }}">
                    <img src="{{ related_product.featured_image | img_url: 'medium' }}"
                        alt="{{ related_product.title }}">
                    <h4>{{ related_product.title }}</h4>
                    <p>{{ related_product.price | money }}</p>
                </a>
            </div>
            {% endif %}
            {% endfor %}
        </div>
        {% endif %}
    </div>
</div>

<style>
    .related-products {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }

    .related-product-item {
        width: calc(33.333% - 20px);
        border: 1px solid #eee;
        padding: 10px;
        text-align: center;
    }

    .related-product-item img {
        max-width: 100%;
        height: auto;
    }

    .related-product-item h4 {
        margin: 10px 0;
    }

    .related-product-item p {
        margin: 0;
    }
</style>
{% schema %}
{
"name": "Related Products",
"tag": "section",
"settings": [

],
"presets": [
{
"name": "Related Products",
"settings": {
}
}
]
}
{% endschema %}