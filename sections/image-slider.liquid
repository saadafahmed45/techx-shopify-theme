<section class="hero-slider-section">
    <div id="heroCarousel-{{ section.id }}" class="carousel slide carousel-fade" data-bs-ride="carousel" {% if
        section.settings.autoplay %} data-bs-interval="{{ section.settings.autoplay_speed | times: 1000 }}" {% endif %}>

        <div class="carousel-inner">
            {% for block in section.blocks %}
            <div class="carousel-item {% if forloop.first %}active{% endif %}">

                {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 2000 }}" class="d-block w-100" alt="Hero Slide"
                    loading="lazy">
                {% else %}
                {{ 'image' | placeholder_svg_tag }}
                {% endif %}

                <div class="carousel-caption d-flex flex-column justify-content-center align-items-center">
                    {% if block.settings.heading != blank %}
                    <h1 class="hero-heading">{{ block.settings.heading }}</h1>
                    {% endif %}
                    {% if block.settings.subheading != blank %}
                    <div class="hero-subheading">{{ block.settings.subheading }}</div>
                    {% endif %}
                    {% if block.settings.button_text != blank %}
                    <a href="{{ block.settings.button_link }}" class="hero-btn">{{ block.settings.button_text }}</a>
                    {% endif %}
                </div>

            </div>
            {% endfor %}
        </div>

        <!-- Controls -->
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel-{{ section.id }}"
            data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>

        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel-{{ section.id }}"
            data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>

    </div>
</section>
{% stylesheet %}

.hero-slider-section {
position: relative;
}

.hero-slider-section img {
height: 90vh;
object-fit: cover;
}

.carousel-caption {
top: 50%;
transform: translateY(-50%);
bottom: unset;
text-align: center;
}

.hero-heading {
font-size: 3rem;
font-weight: 700;
color: #fff;
}

.hero-subheading {
font-size: 1.25rem;
color: #f1f1f1;
margin: 15px 0;
max-width: 800px;
}

.hero-btn {
display: inline-block;
padding: 12px 35px;
background: #000;
color: #fff;
text-decoration: none;
font-weight: 500;
border-radius: 6px;
transition: 0.3s ease;
}

.hero-btn:hover {
background: #333;
}

@media (max-width: 768px) {
.hero-heading {
font-size: 2rem;
}
.hero-subheading {
font-size: 1rem;
}
}

{% endstylesheet %}
{% schema %}
{
"name": "Hero Slider",
"settings": [
{
"type": "checkbox",
"id": "autoplay",
"label": "Enable Autoplay",
"default": true
},
{
"type": "range",
"id": "autoplay_speed",
"label": "Autoplay Speed (Seconds)",
"min": 2,
"max": 10,
"step": 1,
"default": 5
}
],
"blocks": [
{
"type": "slide",
"name": "Slide",
"settings": [
{
"type": "image_picker",
"id": "image",
"label": "Slide Image"
},
{
"type": "text",
"id": "heading",
"label": "Heading"
},
{
"type": "richtext",
"id": "subheading",
"label": "Subheading"
},
{
"type": "text",
"id": "button_text",
"label": "Button Text"
},
{
"type": "url",
"id": "button_link",
"label": "Button Link"
}
]
}
],
"presets": [
{
"name": "Hero Slider",
"category": "Slider",
"blocks": [
{ "type": "slide" },
{ "type": "slide" },
{ "type": "slide" }
]
}
]
}
{% endschema %}