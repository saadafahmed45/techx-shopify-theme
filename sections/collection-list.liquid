<div class="collection-list-section">
    <div class="collection-container">

        <div class="section-heading">
            <h2 class="size-{{ section.settings.heading_size }} text-{{ section.settings.heading_align }}">
                {{ section.settings.heading }}
            </h2>
        </div>

        <div class="collection-grid">
            {% for block in section.blocks limit: section.settings.Collections_to_show %}
            {% assign collection = block.settings.collection %}
            {% if collection != blank %}
            <div class="collection-card">

                <a href="{{ collection.url }}">

                    <div class="collection-image">
                        {% if collection.featured_image %}
                        <img src="{{ collection.featured_image | image_url: width: 600 }}" alt="{{ collection.title }}"
                            loading="lazy">
                        {% else %}
                        {{ 'collection-1' | placeholder_svg_tag }}
                        {% endif %}
                    </div>

                    <div class="collection-content">
                        <h3>{{ collection.title }}</h3>
                        <p>{{ collection.products_count }} Products</p>
                    </div>

                </a>

            </div>
            {% endif %}
            {% endfor %}
        </div>

    </div>
</div>

{% stylesheet %}
.collection-list-section {
padding: 80px 20px;
background: #fff;
}

.collection-container {
max-width: 1200px;
margin: 0 auto;
}

.section-heading {
text-align: center;
margin-bottom: 50px;
}

.section-heading h2 {
/* font-size: 32px; */
font-weight: 700;
margin: 0;
}

.collection-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 30px;
}

.collection-card {
overflow: hidden;
border-radius: 12px;
transition: 0.3s ease;
}

.collection-card a {
text-decoration: none;
color: inherit;
}

.collection-image img {
width: 100%;
height: 300px;
object-fit: cover;
transition: 0.3s ease;
}

.collection-card:hover .collection-image img {
transform: scale(1.05);
}

.collection-content {
padding: 20px;
text-align: center;
background: #f8f9fa;
}

.collection-content h3 {
margin: 0 0 5px;
font-size: 18px;
font-weight: 600;
}

.collection-content p {
margin: 0;
font-size: 14px;
color: #666;
}

/* Tablet */
@media (max-width: 992px) {
.collection-grid {
grid-template-columns: repeat(2, 1fr);
}
}

/* Mobile */
@media (max-width: 600px) {
.collection-grid {
grid-template-columns: 1fr;
}
}
{% endstylesheet %}

{% schema %}
{
"name": "Collection List",
"settings": [
{
"type": "text",
"id": "heading",
"label": "Section Heading",
"default": "Shop by Collection"
},


{
"type": "select",
"id": "heading_size",
"label": "Heading Size",
"default": "lg",
"options": [
{ "value": "sm", "label": "Small" },
{ "value": "md", "label": "Medium" },
{ "value": "lg", "label": "Large" },
{ "value": "xl", "label": "Extra Large" }
]
},
{
"type": "select",
"id": "heading_align",
"label": "Heading Alignment",
"default": "center",
"options": [
{ "value": "left", "label": "Left" },
{ "value": "center", "label": "Center" },
{ "value": "right", "label": "Right" }
]
},
{
"type": "range",
"id": "Collections_to_show",
"label": "Collections to show",
"min": 2,
"max": 12,
"step": 1,
"default": 3
}
],
"blocks": [
{
"type": "collection",
"name": "Collection",
"settings": [
{
"type": "collection",
"id": "collection",
"label": "Select Collection"
}
]
}
],
"presets": [
{
"name": "Collection List",
"blocks": [
{ "type": "collection" },
{ "type": "collection" },
{ "type": "collection" }
]
}
]
}
{% endschema %}