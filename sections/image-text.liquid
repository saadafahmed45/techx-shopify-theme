<div class="img-text-section">
  <div class="img-text-container">
    
    {% if section.settings.image != blank %}
      <div class="img-box">
        <img 
          src="{{ section.settings.image | image_url: width: 800 }}" 
          alt="{{ section.settings.heading }}"
          loading="lazy"
        >
      </div>
    {% endif %}

    <div class="img-text-content">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="img-text-btn">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>

  </div>
</div>

{% stylesheet %}
.img-text-section {
  padding: 80px 20px;
  background: #f9f9f9;
}

.img-text-container {
  /* max-width: 1200px; */
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 60px;
}

.img-box {
  flex: 1;
}

.img-box img {
  width: 100%;
  height: auto;
  border-radius: 12px;
  object-fit: cover;
}

.img-text-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.img-text-content h2 {
  font-size: 32px;
  font-weight: 700;
  margin: 0;
  color: #111;
}

.img-text-content p {
  font-size: 16px;
  line-height: 1.6;
  color: #555;
}

.img-text-btn {
  display: inline-block;
  padding: 12px 28px;
  background: #000;
  color: #fff;
  text-decoration: none;
  font-weight: 500;
  border-radius: 6px;
  transition: 0.3s ease;
  width: 100px;
  text-align: center;
}

.img-text-btn:hover {
  background: #333;
}

/* Responsive */
@media screen and (max-width: 768px) {
  .img-text-container {
    flex-direction: column;
    gap: 30px;
    text-align: center;
  }

  .img-text-content h2 {
    font-size: 26px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Image with Text Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premium Collection"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover high-quality products crafted just for you."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Image with Text",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}